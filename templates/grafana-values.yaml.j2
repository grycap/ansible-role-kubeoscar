admin:
  existingSecret: ""
  user: "{{ grafana_admin_user | default('admin') }}"
  password: "{{ grafana_admin_password | default('admin123') }}"

service:
  type: ClusterIP

persistence:
  enabled: true
  storageClassName: "{{ volume_storage_class_name }}"
  size: 10Gi

datasources:
  datasources.yaml:
    apiVersion: 1
    datasources:
      - name: Prometheus
        type: prometheus
        url: "{{ prometheus_url }}"
        access: proxy
        isDefault: true
      - name: Loki
        type: loki
        url: "{{ loki_url }}"
        access: proxy

dashboardProviders:
  dashboardproviders.yaml:
    apiVersion: 1
    providers:
      - name: default
        orgId: 1
        folder: ""
        type: file
        disableDeletion: false
        editable: true
        options:
          path: /var/lib/grafana/dashboards/default

sidecar:
  dashboards:
    enabled: true
    label: grafana_dashboard
    searchNamespace: ALL

grafana.ini:
  server:
    root_url: "%(protocol)s://%(domain)s:%(http_port)s/"
